---
import Base from "@layouts/Base.astro"
import { getT } from "@lib/i18n"
import PageHero from "@organisms/PageHero.astro"
import ContentSidebar from "@organisms/ContentSidebar.astro"
import ContentSection from "@organisms/ContentSection.astro"
import ContactCTA from "@organisms/ContactCTA.astro"

const t = await getT("es", "cookies")
---

<Base title={t.pageTitle}>
  <PageHero {...t.hero} />
  <section class="px-margin-mobile md:px-margin-desktop max-w-[1200px] mx-auto pb-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <ContentSidebar items={t.sidebar} />
      <div class="md:col-span-9 space-y-8">
        {t.sections.map(s => (
          <ContentSection {...s} />
        ))}
        <ContactCTA {...t.contact} />
      </div>
    </div>
  </section>
</Base>
