---
import ServiceCard from "@molecules/ServiceCard.astro";
import Button from "@atoms/Button.astro";

interface Service {
  icon: string;
  title: string;
  desc: string;
}

interface Props {
  title: string;
  items: Service[];
  cta: string;
}

const { title, items, cta } = Astro.props;
---

<section class="py-20 bg-surface-container-low" id="servicios">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <h2 class="font-inter text-3xl font-semibold text-primary text-center mb-16">{title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {items.map(item => (
        <ServiceCard {...item} />
      ))}
    </div>
    <div class="mt-16 text-center">
      <Button variant="cta" size="lg" href="#contacto" class="bg-[#C05621]">{cta}</Button>
    </div>
  </div>
</section>