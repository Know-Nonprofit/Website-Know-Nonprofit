---
interface Props {
  badge: string
  title: string
  subtitle: string
  image?: string
}

const { badge, title, subtitle, image } = Astro.props
---

<section class="py-12 md:py-16 px-margin-mobile md:px-margin-desktop max-w-[1200px] mx-auto">
  <div class="md:w-2/3 lg:w-1/2 mb-8">
    <span class="inline-block bg-secondary-container text-on-secondary-container font-inter text-xs font-semibold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">
      {badge}
    </span>
    <h1 class="font-inter text-3xl md:text-5xl font-bold text-on-surface mb-4">{title}</h1>
    <p class="font-inter text-lg text-on-surface-variant">{subtitle}</p>
  </div>
  <div class="w-full h-64 md:h-[400px] rounded-xl overflow-hidden mb-8 relative">
    {image && (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent"></div>
  </div>
</section>
