---
import NavLogo from "@molecules/NavLogo.astro";

interface Link {
  label: string;
  href: string;
}

interface Props {
  brand: string;
  tagline: string;
  links: Link[];
}

const { brand, tagline, links } = Astro.props;
---

<footer class="bg-surface-container-low border-t border-outline-variant text-on-surface">
  <div class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-20 max-w-[1200px] mx-auto gap-8">
    <div class="flex flex-col items-center md:items-start">
      <NavLogo icon="🏗" text={brand} />
      <p class="font-inter text-base text-on-surface-variant text-center md:text-left max-w-sm mt-4">
        {tagline}
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
      {links.map(link => (
        <a href={link.href} class="text-on-surface-variant font-inter text-sm font-semibold hover:text-secondary underline decoration-2 underline-offset-4 transition-all duration-300 ease-in-out">
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex gap-4">
      <a class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high hover:bg-primary hover:text-white transition-all" href="#">
        <span>🔗</span>
      </a>
      <a class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high hover:bg-primary hover:text-white transition-all" href="#">
        <span>✉️</span>
      </a>
    </div>
  </div>
</footer>