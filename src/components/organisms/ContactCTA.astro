---
import Icon from "@atoms/Icon.astro"
import Button from "@atoms/Button.astro"

interface Props {
  id: string
  title: string
  subtitle: string
  email: string
  emailLabel: string
}

const { id, title, subtitle, email, emailLabel } = Astro.props
---

<div id={id} class="bg-surface-container-high p-6 md:p-8 rounded-xl border border-outline-variant">
  <h2 class="font-inter text-xl font-bold text-on-surface mb-3">{title}</h2>
  <p class="font-inter text-base text-on-surface-variant mb-6">{subtitle}</p>
  <div class="flex flex-col sm:flex-row gap-4">
    <Button variant="primary" href={`mailto:${email}`} class="inline-flex items-center gap-2">
      <Icon name="Mail" size={18} />
      {emailLabel}
    </Button>
  </div>
</div>
