---
interface Item {
  label: string
  href: string
}

interface Props {
  items: Item[]
}

const { items } = Astro.props
---

<aside class="hidden md:block md:col-span-3 sticky top-24 h-fit">
  <nav class="flex flex-col gap-3 border-l border-outline-variant pl-4">
    {items.map(item => (
      <a
        href={item.href}
        class="font-inter text-sm font-medium text-on-surface-variant hover:text-secondary transition-colors"
      >
        {item.label}
      </a>
    ))}
  </nav>
</aside>
