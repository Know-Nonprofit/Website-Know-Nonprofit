---
interface Props {
  country: string;
  title: string;
  desc: string;
  image: string;
  link: string;
}

const { country, title, desc, image, link } = Astro.props;
---

<div class="flex flex-col md:flex-row bg-white border border-outline-variant rounded-xl overflow-hidden hover:shadow-lg transition-all group">
  <div class="w-full md:w-1/3 h-48 md:h-auto overflow-hidden">
    <img alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src={image} />
  </div>
  <div class="p-8 flex flex-col justify-center w-full md:w-2/3">
    <span class="text-secondary font-inter text-sm font-semibold uppercase tracking-wider mb-2">{country}</span>
    <h3 class="font-inter text-2xl font-semibold text-primary mb-2">{title}</h3>
    <p class="text-on-surface-variant font-inter text-base">{desc}</p>
    <a href="#" class="mt-4 text-primary font-inter text-sm font-semibold flex items-center gap-1 hover:underline group-hover:gap-2 transition-all w-fit">
      {link}
      <span>→</span>
    </a>
  </div>
</div>