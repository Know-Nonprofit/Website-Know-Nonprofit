---
import Icon from "@atoms/Icon.astro";

interface Props {
  icon: string;
  title: string;
  desc: string;
}

const { icon, title, desc } = Astro.props;
---

<div class="group p-8 bg-surface-container-lowest border border-outline-variant rounded-xl hover:shadow-md transition-all">
  <div class="flex items-center gap-3 mb-4">
    <Icon name={icon} size={24} class="text-error" />
    <h3 class="font-inter text-2xl font-semibold text-primary">{title}</h3>
  </div>
  <p class="text-on-surface-variant font-inter text-base">{desc}</p>
</div>