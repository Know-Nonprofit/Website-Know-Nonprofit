---
interface Props {
  variant?: "primary" | "secondary" | "outline" | "cta";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit";
  href?: string;
  class?: string;
}

const { variant = "primary", size = "md", type = "button", href, class: className = "" } = Astro.props;

const base = "inline-flex items-center justify-center font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2";

const variants = {
  primary: "bg-primary text-on-primary hover:bg-opacity-90",
  secondary: "bg-secondary text-on-secondary hover:bg-opacity-90",
  outline: "border border-primary text-primary hover:bg-surface-container-low",
  cta: "bg-primary text-on-primary hover:bg-opacity-90 shadow-sm font-semibold"
};

const sizes = {
  sm: "px-4 py-2 text-sm rounded-lg",
  md: "px-6 py-3 text-base rounded-lg",
  lg: "px-8 py-4 text-base rounded-lg"
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes}><slot /></a>
) : (
  <button type={type} class={classes}><slot /></button>
)}