---
import ProjectCard from "@modules/molecules/cards/ProjectCard.astro";

interface Project {
  country: string;
  title: string;
  desc: string;
  image: string;
  link: string;
  cta?: string;
}

interface Props {
  title: string;
  items: Project[];
}

const { title, items } = Astro.props;
---

<section class="py-20 bg-surface-container-lowest" id="proyectos">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <h2 class="font-inter text-3xl font-semibold text-primary mb-12">{title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {items.map(item => (
        <ProjectCard {...item} />
      ))}
    </div>
  </div>
</section>