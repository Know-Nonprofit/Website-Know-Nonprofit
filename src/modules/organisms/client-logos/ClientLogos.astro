---
interface Props {
  title: string;
  subtitle: string;
  tagline?: string;
  logo?: string;
}

const { title, subtitle, tagline, logo } = Astro.props;
---

<section class="py-20 bg-surface-container-low" id="quien-soy">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="text-center mb-12">
      <h2 class="font-inter text-3xl font-semibold text-primary mb-4">{title}</h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto">{subtitle}</p>
    </div>
    {logo && (
      <div class="text-center">
        {tagline && <p class="text-sm font-semibold text-on-surface-variant uppercase tracking-widest mb-4">{tagline}</p>}
        <div class="flex justify-center">
          <img
            src={logo}
            alt="CFA"
            class="h-20 opacity-60 hover:opacity-100 transition-opacity"
          />
        </div>
      </div>
    )}
  </div>
</section>
