---
import CheckItem from "@modules/molecules/list/CheckItem.astro";

interface Props {
  title: string;
  subtitle: string;
  features: string[];
  image: string;
}

const { title, subtitle, features, image } = Astro.props;
---

<section class="py-20 bg-primary-container text-on-primary">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="relative">
      <div class="aspect-video bg-surface-container-high rounded-xl overflow-hidden border border-outline-variant">
        <img alt="Collaboration for Social Good" class="w-full h-full object-cover" src={image} />
      </div>

    </div>
    <div>
      <h2 class="font-inter text-3xl font-semibold mb-6">{title}</h2>
      <p class="font-inter text-lg text-on-primary-container leading-relaxed mb-8">
        {subtitle}
      </p>
      <ul class="space-y-4">
        {features.map(feature => (
          <CheckItem text={feature} />
        ))}
      </ul>
    </div>
  </div>
</section>