---
import Button from "@modules/atoms/buttons/Button.astro";
import Icon from "@modules/atoms/icons/Icon.astro";

interface Props {
  title: string;
  subtitle: string;
  cta: string;
  ctaSecondary: string;
  image: string;
  badge: { icon: string; text: string };
}

const { title, subtitle, cta, ctaSecondary, image, badge } = Astro.props;
---

<section class="relative overflow-hidden bg-surface-container-lowest py-20 md:py-32 border-b border-outline-variant">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-7">
      <h1 class="font-inter text-4xl md:text-5xl font-bold text-primary mb-6 leading-tight">
        <Fragment set:html={title} />
      </h1>
      <p class="font-inter text-lg text-on-surface-variant mb-10 max-w-2xl">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <Button variant="cta" size="lg" href="#contacto" class="bg-[#C05621]">{cta}</Button>
        <Button variant="outline" size="lg" href="#proyectos">{ctaSecondary}</Button>
      </div>
    </div>
    <div class="md:col-span-5 relative">
      <div class="aspect-square bg-surface-container-low rounded-xl overflow-hidden shadow-sm border border-outline-variant">
        <img alt="Software Architectural Reliability" class="w-full h-full object-cover grayscale-[20%]" src={image} />
      </div>
      <div class="absolute -bottom-6 -left-6 bg-secondary-container p-6 rounded-lg shadow-lg border border-secondary hidden md:block max-w-[200px]">
        <Icon name={badge.icon} size={40} class="text-on-secondary-container mb-2" />
        <p class="font-inter text-sm font-semibold text-on-secondary-container">{badge.text}</p>
      </div>
    </div>
  </div>
</section>