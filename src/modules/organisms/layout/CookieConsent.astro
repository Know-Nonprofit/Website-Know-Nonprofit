---
import { getRelativeLocaleUrl } from "astro:i18n"

const locale = Astro.currentLocale ?? "es"

const termsUrl   = getRelativeLocaleUrl(locale, locale === "es" ? "terminos"   : "terms")
const privacyUrl = getRelativeLocaleUrl(locale, locale === "es" ? "privacidad" : "privacy")
const cookiesUrl = getRelativeLocaleUrl(locale, "cookies")

const t = locale === "es" ? {
  title: "Privacidad",
  body: "Usamos cookies para mejorar tu experiencia.",
  privacy: "Privacidad",
  terms: "Términos",
  cookies: "Cookies",
  reject: "Rechazar",
  accept: "Aceptar",
} : {
  title: "Privacy",
  body: "We use cookies to improve your experience.",
  privacy: "Privacy",
  terms: "Terms",
  cookies: "Cookies",
  reject: "Reject",
  accept: "Accept",
}
---

<style>
  .cookie-enter {
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .cookie-enter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .cookie-exit {
    opacity: 0 !important;
    transform: translateY(100%) !important;
    transition: opacity 0.4s ease-in, transform 0.4s ease-in;
  }
</style>

<div id="cookie-consent" class="cookie-enter fixed bottom-0 left-0 right-0 z-[100] bg-secondary border-t border-white/20 shadow-[0_-4px_24px_rgba(0,0,0,0.2)]">
  <div class="max-w-[1200px] mx-auto px-4 md:px-margin-desktop py-4 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-start gap-3">
      <span class="w-2.5 h-2.5 rounded-full bg-white animate-pulse shrink-0 mt-1.5"></span>
      <div>
        <p class="font-inter text-sm text-white font-semibold">
          {t.title}
        </p>
        <p class="font-inter text-sm text-white/80 leading-relaxed">
          {t.body}
        </p>
        <div class="flex flex-wrap gap-x-4 gap-y-1 mt-1.5 text-xs">
          <a href={termsUrl}   class="text-[#86f2e4] font-medium underline underline-offset-2 hover:text-white transition-colors">{t.terms}</a>
          <a href={privacyUrl} class="text-[#86f2e4] font-medium underline underline-offset-2 hover:text-white transition-colors">{t.privacy}</a>
          <a href={cookiesUrl} class="text-[#86f2e4] font-medium underline underline-offset-2 hover:text-white transition-colors">{t.cookies}</a>
        </div>
      </div>
    </div>
    <div class="flex gap-3 shrink-0">
      <button id="cookie-reject" type="button" class="px-4 py-2 rounded-lg border border-white/40 text-white text-sm font-medium bg-transparent hover:bg-white/10 transition-colors">
        {t.reject}
      </button>
      <button id="cookie-accept" type="button" class="px-4 py-2 rounded-lg bg-white text-secondary text-sm font-medium hover:bg-white/90 transition-colors shadow-lg">
        {t.accept}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const KEY = "cookie-consent"
    var banner = document.getElementById("cookie-consent")
    if (!banner) return

    if (localStorage.getItem(KEY)) {
      banner.classList.add("hidden")
      return
    }

    setTimeout(function() {
      banner.classList.remove("hidden")
      banner.classList.add("is-visible")
    }, 1200)

    function dismiss() {
      banner.classList.remove("is-visible")
      banner.classList.add("cookie-exit")
      setTimeout(function() {
        banner.classList.add("hidden")
      }, 400)
    }

    document.getElementById("cookie-accept")?.addEventListener("click", function() {
      localStorage.setItem(KEY, "accepted")
      document.dispatchEvent(new CustomEvent("consent:accepted"))
      dismiss()
    })

    document.getElementById("cookie-reject")?.addEventListener("click", function() {
      localStorage.setItem(KEY, "rejected")
      dismiss()
    })
  })()
</script>
