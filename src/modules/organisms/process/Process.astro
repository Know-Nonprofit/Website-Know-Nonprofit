---
import ProcessStep from "@modules/molecules/steps/ProcessStep.astro";

interface Step {
  number: number;
  title: string;
  desc: string;
}

interface Props {
  title: string;
  subtitle: string;
  steps: Step[];
}

const { title, subtitle, steps } = Astro.props;
---

<section class="py-20 bg-surface-container-lowest">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="text-center mb-20">
      <h2 class="font-inter text-3xl font-semibold text-primary">{title}</h2>
      <p class="text-on-surface-variant mt-2">{subtitle}</p>
    </div>
    <div class="relative">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {steps.map(step => (
          <ProcessStep {...step} />
        ))}
      </div>
    </div>
  </div>
</section>