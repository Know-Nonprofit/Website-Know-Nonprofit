---
import TextBlock from "@modules/atoms/text/TextBlock.astro";

interface Props {
  heading: string;
  body: string;
  listItems?: string[];
}

const { heading, body, listItems = [] } = Astro.props;
---

<div class="flex flex-col gap-4 pt-6">
  <TextBlock as="h2" text={heading} class="text-2xl font-semibold text-primary leading-8" />
  <TextBlock as="p" text={body} class="text-lg text-on-surface-variant leading-7" />
  {listItems.length > 0 && (
    <ul class="flex flex-col gap-2 pt-2">
      {listItems.map(item => (
        <li class="pl-6 relative text-lg text-on-surface-variant leading-7">
          <span class="absolute left-0 top-0 text-secondary font-bold">•</span>
          {item}
        </li>
      ))}
    </ul>
  )}
</div>
