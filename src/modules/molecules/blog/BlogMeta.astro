---
import Badge from "@modules/atoms/badges/Badge.astro";
import Icon from "@modules/atoms/icons/Icon.astro";
import TextBlock from "@modules/atoms/text/TextBlock.astro";

interface Props {
  category: string;
  title: string;
  date: string;
  readTime: string;
}

const { category, title, date, readTime } = Astro.props;
---

<div class="flex flex-col gap-4">
  <Badge label={category} />
  <TextBlock as="h1" text={title} class="text-3xl font-bold text-primary leading-10" />
  <div class="flex items-center gap-6">
    <div class="flex items-center gap-1">
      <Icon name="Calendar" size={14} class="text-on-surface-variant" />
      <span class="text-on-surface-variant text-sm font-normal font-inter leading-5">{date}</span>
    </div>
    <div class="flex items-center gap-1">
      <Icon name="Clock" size={14} class="text-on-surface-variant" />
      <span class="text-on-surface-variant text-sm font-normal font-inter leading-5">{readTime}</span>
    </div>
  </div>
</div>
