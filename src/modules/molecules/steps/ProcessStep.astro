---
interface Props {
  number: number;
  title: string;
  desc: string;
}

const { number, title, desc } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center text-white font-bold text-xl mb-6 shadow-md">
    {number}
  </div>
  <h3 class="font-inter text-2xl font-semibold text-primary mb-3">{title}</h3>
  <p class="text-on-surface-variant font-inter text-base">{desc}</p>
</div>