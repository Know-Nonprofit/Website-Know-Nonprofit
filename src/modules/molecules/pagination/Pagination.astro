---
import Icon from "@modules/atoms/icons/Icon.astro";

interface Props {
  currentPage: number;
  totalPages: number;
  prevLabel?: string;
  nextLabel?: string;
  basePath: string;
}

const { currentPage, totalPages, prevLabel = "Previous", nextLabel = "Next", basePath } = Astro.props;

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);

function pageUrl(page: number) {
  return page === 1 ? basePath + "/" : basePath + "/page/" + page + "/";
}
---

<nav class="inline-flex justify-center items-center gap-4" aria-label="Pagination">
  {currentPage > 1 ? (
    <a href={pageUrl(currentPage - 1)} class="p-2 rounded-full border border-outline-variant hover:bg-surface-container-low transition-colors" aria-label={prevLabel}>
      <Icon name="ChevronLeft" size={16} class="text-primary" />
    </a>
  ) : (
    <span class="p-2 rounded-full border border-outline-variant opacity-30" aria-label={prevLabel}>
      <Icon name="ChevronLeft" size={16} class="text-primary" />
    </span>
  )}

  <div class="flex justify-start items-center gap-1">
    {pages.map(page => (
      page === currentPage ? (
        <span class="w-10 h-10 py-2.5 rounded-full flex justify-center items-center font-inter text-sm font-semibold leading-5 tracking-tight bg-secondary text-on-secondary" aria-current="page">
          {page}
        </span>
      ) : (
        <a href={pageUrl(page)} class="w-10 h-10 py-2.5 rounded-full flex justify-center items-center font-inter text-sm font-semibold leading-5 tracking-tight text-primary hover:bg-surface-container-low transition-colors" aria-label={`Page ${page}`}>
          {page}
        </a>
      )
    ))}
  </div>

  {currentPage < totalPages ? (
    <a href={pageUrl(currentPage + 1)} class="p-2 rounded-full border border-outline-variant hover:bg-surface-container-low transition-colors" aria-label={nextLabel}>
      <Icon name="ChevronRight" size={16} class="text-primary" />
    </a>
  ) : (
    <span class="p-2 rounded-full border border-outline-variant opacity-30" aria-label={nextLabel}>
      <Icon name="ChevronRight" size={16} class="text-primary" />
    </span>
  )}
</nav>
