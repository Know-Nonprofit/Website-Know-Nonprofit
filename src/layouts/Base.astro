---
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
const locale = Astro.currentLocale ?? "es";
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{locale === "es" ? "Sitio" : "Site"}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>