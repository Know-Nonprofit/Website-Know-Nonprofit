---
import "@styles/tailwind.css";
import Navbar from "@modules/organisms/layout/Navbar.astro";
import Footer from "@modules/organisms/layout/Footer.astro";
import CookieConsent from "@modules/organisms/layout/CookieConsent.astro";
import { getT } from "@lib/i18n";
import routes from "@i18n/routes.json";
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? "es";
const nav = await getT(locale, "nav");
const footer = await getT(locale, "footer");

const { title, description, ogType } = Astro.props;

const pageTitle = title ?? "Sebastián Tamayo"

const metaDescription = description ?? (locale === "es"
  ? "Desarrollo web, consultoría tecnológica y transformación digital para organizaciones del sector social."
  : "Web development, technology consulting, and digital transformation for the social sector.")

// Canonical URL
const canonical = new URL(Astro.url.pathname, Astro.url.origin).href

// Hreflang URLs
const isEnPath = Astro.url.pathname.startsWith("/en/") || Astro.url.pathname === "/en"
const slug = isEnPath
  ? Astro.url.pathname.replace("/en", "").replace(/\/$/, "") || "/"
  : Astro.url.pathname.replace(/\/$/, "") || "/"
const normSlug = slug === "/" ? "" : slug.replace(/^\//, "")

const esNormSlug = locale === "en" ? (routes.es[normSlug] ?? normSlug) : normSlug
const enNormSlug = locale === "es" ? (routes.en[normSlug] ?? normSlug) : normSlug

const esUrl = new URL(getRelativeLocaleUrl("es", esNormSlug), Astro.url.origin).href
const enUrl = new URL(getRelativeLocaleUrl("en", enNormSlug), Astro.url.origin).href

// OG image
const ogImage = new URL("/og-image.svg", Astro.url.origin).href

// JSON-LD
const schemaBase = {
  "@context": "https://schema.org",
}

const organizationSchema = {
  ...schemaBase,
  "@type": "Organization",
  "name": "Sebastián Tamayo",
  "url": Astro.url.origin,
  "logo": new URL("/favicon.svg", Astro.url.origin).href,
}

const websiteSchema = {
  ...schemaBase,
  "@type": "WebSite",
  "name": "Sebastián Tamayo",
  "url": Astro.url.origin,
}

const personSchema = {
  ...schemaBase,
  "@type": "Person",
  "name": "Sebastián Tamayo",
  "url": Astro.url.origin,
  "sameAs": [
    "https://www.linkedin.com/in/tamaytamaytamay/",
    "https://github.com/tamaytamaytamay",
  ],
}

const schemas = [organizationSchema, websiteSchema, personSchema]
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={locale === "es" ? esUrl : enUrl} />

    <meta property="og:type" content={ogType ?? "website"} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Sebastián Tamayo" />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@tamaytamay_" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta name="theme-color" content="#131b2e" />

    <script type="application/ld+json" set:html={JSON.stringify(schemas)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <script is:inline>
      (function() {
        var KEY = "cookie-consent"
        function loadClarity() {
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "x0wykp2o80")
        }
        var stored = localStorage.getItem(KEY)
        if (stored === "accepted") {
          loadClarity()
        } else if (!stored) {
          document.addEventListener("consent:accepted", loadClarity)
        }
      })()
    </script>
  </head>
  <body class="bg-background text-on-surface font-inter">
    <CookieConsent />
    <Navbar {...nav} />
    <slot />
    <Footer {...footer} />
  </body>
</html>
