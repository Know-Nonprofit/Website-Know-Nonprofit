---
import "@styles/tailwind.css";
import Navbar from "@organisms/Navbar.astro";
import Footer from "@organisms/Footer.astro";
import CookieConsent from "@organisms/CookieConsent.astro";
import { getT } from "@lib/i18n";
import routes from "@i18n/routes.json";
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? "es";
const nav = await getT(locale, "nav");
const footer = await getT(locale, "footer");

const { title, description } = Astro.props;

const pageTitle = title ?? (locale === "es"
  ? "SustainSoft | Consultoría de Software para ONGs"
  : "SustainSoft | Software Consulting for NGOs")

const metaDescription = description ?? (locale === "es"
  ? "SustainSoft — Consultoría de software especializada para ONGs. Desarrollo web, automatización y tecnología social."
  : "SustainSoft — Specialized software consulting for NGOs. Web development, automation, and social technology.")

// Canonical URL
const canonical = new URL(Astro.url.pathname, Astro.url.origin).href

// Hreflang URLs
const isEnPath = Astro.url.pathname.startsWith("/en/") || Astro.url.pathname === "/en"
const slug = isEnPath
  ? Astro.url.pathname.replace("/en", "").replace(/\/$/, "") || "/"
  : Astro.url.pathname.replace(/\/$/, "") || "/"
const normSlug = slug === "/" ? "" : slug.replace(/^\//, "")

const esNormSlug = locale === "en" ? (routes.es[normSlug] ?? normSlug) : normSlug
const enNormSlug = locale === "es" ? (routes.en[normSlug] ?? normSlug) : normSlug

const esUrl = new URL(getRelativeLocaleUrl("es", esNormSlug), Astro.url.origin).href
const enUrl = new URL(getRelativeLocaleUrl("en", enNormSlug), Astro.url.origin).href

// OG image
const ogImage = new URL("/og-image.png", Astro.url.origin).href

// JSON-LD
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SustainSoft",
  "url": Astro.url.origin,
  "logo": new URL("/favicon.svg", Astro.url.origin).href,
  "description": metaDescription
}
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={locale === "es" ? esUrl : enUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="SustainSoft" />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <script is:inline>
      (function() {
        var KEY = "cookie-consent"
        function loadClarity() {
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "x0wykp2o80")
        }
        var stored = localStorage.getItem(KEY)
        if (stored === "accepted") {
          loadClarity()
        } else if (!stored) {
          document.addEventListener("consent:accepted", loadClarity)
        }
      })()
    </script>
  </head>
  <body class="bg-background text-on-surface font-inter">
    <CookieConsent />
    <Navbar {...nav} />
    <slot />
    <Footer {...footer} />
  </body>
</html>
